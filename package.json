    "prop-types": "^15.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-json-tree": "^0.20.0",
    "riscos-artworks": "git+https://git@github.com/RichardBrown384/riscos-artworks-js.git",
    "riscos-file-formats": "git+https://git@github.com/RichardBrown384/riscos-file-formats-js.git"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@vitejs/plugin-react": "^5.1.4",
